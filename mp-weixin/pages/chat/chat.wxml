<view><view class="cu-chat"><block wx:for="{{list}}" wx:for-item="item" wx:for-index="index" wx:key="index"><view><block wx:if="{{item.ask}}"><view class="cu-item self"><view class="main"><view class="content bg-green shadow"><block wx:if="{{!item.imgAsk}}"><text>{{item.ask}}</text></block><block wx:if="{{item.imgAsk}}"><image style="width:120rpx;" src="{{baseUrl+item.imgAsk}}" mode="widthFix" data-event-opts="{{[['tap',[['imgView',['$0'],[[['list','',index,'imgAsk']]]]]]]}}" bindtap="__e"></image></block></view></view><view class="cu-avatar radius" style="background-image:url(https://ossweb-img.qq.com/images/lol/web201310/skin/big107000.jpg);"></view></view></block><block wx:if="{{item.reply}}"><view class="cu-item"><view class="cu-avatar radius" style="background-image:url(https://ossweb-img.qq.com/images/lol/web201310/skin/big143004.jpg);"></view><view class="main"><view class="content shadow"><block wx:if="{{!item.imgReply}}"><text>{{item.reply}}</text></block><block wx:if="{{item.imgReply}}"><image style="width:120rpx;" src="{{baseUrl+item.imgReply}}" mode="widthFix" data-event-opts="{{[['tap',[['imgView',['$0'],[[['list','',index,'imgReply']]]]]]]}}" bindtap="__e"></image></block></view></view></view></block></view></block></view><view class="cu-bar foot input"><input class="solid-bottom" adjust-position="{{false}}" focus="{{false}}" maxlength="300" cursor-spacing="10" data-event-opts="{{[['input',[['__set_model',['','ask','$event',[]]]]]]}}" value="{{ask}}" bindinput="__e"/><button data-event-opts="{{[['tap',[['onSendTap',['$event']]]]]}}" class="cu-btn bg-green shadow" bindtap="__e">发送</button></view></view>