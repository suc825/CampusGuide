.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0faf7 0%, #fff 100%);
  padding: 40rpx 32rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #203630;
  letter-spacing: 4rpx;
}

.content {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.content rich-text {
  font-size: 30rpx;
  color: #333;
  line-height: 2;
}

.content rich-text img {
  max-width: 100% !important;
  height: auto !important;
  border-radius: 16rpx;
  margin: 20rpx 0;
  display: block;
}

.content rich-text a {
  color: #2f7a69;
  text-decoration: underline;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.file-section {
  margin-top: 30rpx;
  border-top: 2rpx solid #eee;
  padding-top: 30rpx;
}

.file-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #203630;
  margin-bottom: 20rpx;
}

.file-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #f0faf7;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.file-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.file-name {
  font-size: 28rpx;
  color: #2f7a69;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
